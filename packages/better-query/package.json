{
	"name": "better-query",
	"version": "0.1.1",
	"type": "module",
	"description": "Type-safe CRUD generator with auto-generated REST APIs for Node.js applications",
	"author": "armelgeek",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/armelgeek/better-query.git",
		"directory": "packages/better-query"
	},
	"keywords": [
		"crud",
		"api",
		"rest",
		"typescript",
		"generator",
		"kysely",
		"zod",
		"database",
		"orm"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup --clean",
		"dev": "tsup --watch",
		"test": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": "./dist/index.js",
		"./client": "./dist/client.js",
		"./adapters": "./dist/adapters.js",
		"./plugins": "./dist/plugins.js"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1061.0",
		"@aws-sdk/s3-request-presigner": "^3.1061.0",
		"@better-fetch/fetch": "^1.1.4",
		"@paralleldrive/cuid2": "^2.2.2",
		"better-call": "^0.1.20",
		"kysely": "^0.27.4",
		"nodemailer": "^8.0.10",
		"ws": "^8.18.3",
		"zod": "^3.22.5"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.11",
		"@types/nodemailer": "^8.0.0",
		"@types/ws": "^8.18.1",
		"better-auth": "^1.3.18",
		"better-sqlite3": "^11.1.2",
		"tsup": "^8.2.4",
		"type-fest": "^4.41.0",
		"typescript": "^5.5.0-dev.20240508",
		"vitest": "^1.6.0"
	},
	"files": [
		"dist",
		"CHANGELOG.md",
		"README.md"
	]
}
