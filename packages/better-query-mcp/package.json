{
	"name": "better-query-mcp",
	"version": "0.1.0",
	"type": "module",
	"description": "Model Context Protocol (MCP) server for better-query - enables AI assistants to interact with better-query APIs",
	"author": "armelgeek",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/armelgeek/better-query.git",
		"directory": "packages/better-query-mcp"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"ai",
		"better-query",
		"crud",
		"api",
		"typescript"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup --clean",
		"dev": "tsup --watch",
		"test": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"better-query-mcp": "./dist/index.js"
	},
	"exports": {
		".": "./dist/index.js"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.0.4",
		"better-query": "workspace:*",
		"zod": "^3.22.5"
	},
	"devDependencies": {
		"@types/node": "^20.12.12",
		"tsup": "^8.2.4",
		"typescript": "^5.5.0-dev.20240508",
		"vitest": "^1.6.0"
	},
	"files": [
		"dist",
		"CHANGELOG.md",
		"README.md"
	]
}
